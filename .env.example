OPENAI_API_KEY=
MODEL_NAME="gpt-realtime"

# BKC / Nextspace LLM Engine live transcript bridge for `berky-reachy`.
BERKIE_LLM_ENGINE_BASE_URL=http://localhost:3000/v1
BERKY_LLM_ENGINE_SOCKET_URL=http://localhost:5555
BERKIE_LLM_ENGINE_CONVERSATION_ID=
BERKIE_LLM_ENGINE_TOKEN=
# Or use username/password instead of BERKIE_LLM_ENGINE_TOKEN:
# BERKIE_LLM_ENGINE_USERNAME=
# BERKIE_LLM_ENGINE_PASSWORD=

# Transcript chunks are sent to this incoming audio/transcript channel.
BERKY_TRANSCRIPT_CHANNEL=transcript
BERKY_TRANSCRIPT_CHANNEL_PASSCODE=

# Agent messages from these channels are spoken by Reachy.
BERKY_RESPONSE_CHANNELS=chat

# Wake-word handling is done by the LLM Engine Berky agent.
BERKY_WAKE_PHRASE="hey berkie"
BERKIE_LLM_ENGINE_BOT_NAME=Berkie

# Local Whisper segmentation.
BERKY_WHISPER_MODEL=base.en
BERKY_WHISPER_DEVICE=auto
BERKY_WHISPER_COMPUTE_TYPE=default
BERKY_TRANSCRIBE_WINDOW_SECONDS=6
BERKY_SILENCE_SECONDS=0.8
BERKY_SPEECH_RMS_THRESHOLD=0.012

# Optional local TTS command. Use {text} as the utterance placeholder.
# Defaults to `say {text}` on macOS, then `espeak-ng {text}` / `espeak {text}` when available.
# BERKY_TTS_COMMAND="say --voice Samantha {text}"

# Local vision model (only used with --local-vision CLI flag)
# By default, vision is handled by gpt-realtime when the camera tool is used
LOCAL_VISION_MODEL=HuggingFaceTB/SmolVLM2-2.2B-Instruct

# Cache for local VLM (only used with --local-vision CLI flag)
HF_HOME=./cache

# Hugging Face token for accessing datasets/models
HF_TOKEN=

# Profile selection (defaults to "default" when unset)
REACHY_MINI_CUSTOM_PROFILE="example"

# Optional external profile/tool directories
# REACHY_MINI_EXTERNAL_PROFILES_DIRECTORY=external_content/external_profiles
# REACHY_MINI_EXTERNAL_TOOLS_DIRECTORY=external_content/external_tools

# Optional: discover and auto-load all tools found in REACHY_MINI_EXTERNAL_TOOLS_DIRECTORY,
# even if they are not listed in the selected profile's tools.txt.
# This is convenient for downloaded tools used with built-in/default profiles.
# AUTOLOAD_EXTERNAL_TOOLS=1
